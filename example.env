# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Impala (optional — only needed for online mode) ───────────────────────────
IMPALA_HOST=your-impala-host.internal
IMPALA_PORT=21050
IMPALA_AUTH_MECHANISM=NOSASL   # or PLAIN / GSSAPI / LDAP

# ── DuckDB ────────────────────────────────────────────────────────────────────
DUCKDB_PATH=metadata.duckdb

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
